      "description": "General association",
      "from": [],
      "to": [],
      "symmetric": true
    },
    "supports": {
      "@id": "mif:relationship/supports",
      "@type": "mif:Relationship",
      "name": "supports",
      "description": "Infrastructure or practice supports an operation",
      "from": [
