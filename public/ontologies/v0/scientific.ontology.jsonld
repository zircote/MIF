{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://mif-spec.dev/ns/ontology#",
    "mif": "https://mif-spec.dev/ns/",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ontology": {
      "@id": "mif:Ontology",
      "@type": "@id"
    },
    "id": {
      "@id": "@id"
    },
    "version": {
      "@id": "schema:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "schema_url": {
      "@id": "rdfs:isDefinedBy",
      "@type": "@id"
    },
    "namespaces": {
      "@id": "mif:hasNamespace",
      "@container": "@id"
    },
    "type_hint": {
      "@id": "mif:typeHint",
      "@type": "xsd:string"
    },
    "replaces": {
      "@id": "mif:replaces",
      "@type": "@id"
    },
    "children": {
      "@id": "mif:hasChildNamespace",
      "@container": "@id"
    },
    "entity_types": {
      "@id": "mif:definesEntityType",
      "@container": "@list"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "base": {
      "@id": "mif:baseType",
      "@type": "@vocab"
    },
    "semantic": "mif:SemanticMemory",
    "episodic": "mif:EpisodicMemory",
    "procedural": "mif:ProceduralMemory",
    "traits": {
      "@id": "mif:definesTrait",
      "@container": "@id"
    },
    "subtype_of": {
      "@id": "mif:subtypeOf",
      "@type": "@id",
      "@container": "@set"
    },
    "fields": {
      "@id": "mif:hasField",
      "@container": "@id"
    },
    "requires": {
      "@id": "mif:requiresField",
      "@container": "@list"
    },
    "relationships": {
      "@id": "mif:definesRelationship",
      "@container": "@id"
    },
    "from": {
      "@id": "rdfs:domain",
      "@container": "@set"
    },
    "to": {
      "@id": "rdfs:range",
      "@container": "@set"
    },
    "symmetric": {
      "@id": "owl:SymmetricProperty",
      "@type": "xsd:boolean"
    },
    "discovery": {
      "@id": "mif:discoveryConfig"
    },
    "enabled": {
      "@id": "mif:discoveryEnabled",
      "@type": "xsd:boolean"
    },
    "patterns": {
      "@id": "mif:hasDiscoveryPattern",
      "@container": "@list"
    },
    "confidence_threshold": {
      "@id": "mif:confidenceThreshold",
      "@type": "xsd:decimal"
    },
    "content_pattern": {
      "@id": "mif:contentPattern",
      "@type": "xsd:string"
    },
    "file_pattern": {
      "@id": "mif:filePattern",
      "@type": "xsd:string"
    },
    "suggest_entity": {
      "@id": "mif:suggestsEntityType",
      "@type": "@id"
    },
    "suggest_namespace": {
      "@id": "mif:suggestsNamespace",
      "@type": "xsd:string"
    }
  },
  "@id": "mif:ontology/scientific",
  "@type": "mif:Ontology",
  "identifier": "scientific",
  "version": "0.2.1",
  "description": "Scientific research domain ontology \u2014 studies, methods, data, provenance",
  "namespaces": {
    "semantic": {
      "@id": "mif:namespace/semantic",
      "@type": "mif:Namespace",
      "name": "semantic",
      "children": {
        "science": {
          "@id": "mif:namespace/semantic/science",
          "@type": "mif:Namespace",
          "name": "science",
          "description": "Hypotheses, methods, measurements, samples",
          "type_hint": "semantic"
        },
        "instruments": {
          "@id": "mif:namespace/semantic/instruments",
          "@type": "mif:Namespace",
          "name": "instruments",
          "description": "Research instruments and devices",
          "type_hint": "semantic"
        },
        "catalogs": {
          "@id": "mif:namespace/semantic/catalogs",
          "@type": "mif:Namespace",
          "name": "catalogs",
          "description": "Datasets, catalogs, distributions, services",
          "type_hint": "semantic"
        },
        "publications": {
          "@id": "mif:namespace/semantic/publications",
          "@type": "mif:Namespace",
          "name": "publications",
          "description": "Research publications and scholarly outputs",
          "type_hint": "semantic"
        },
        "funding": {
          "@id": "mif:namespace/semantic/funding",
          "@type": "mif:Namespace",
          "name": "funding",
          "description": "Grants and research funding",
          "type_hint": "semantic"
        }
      }
    },
    "episodic": {
      "@id": "mif:namespace/episodic",
      "@type": "mif:Namespace",
      "name": "episodic",
      "children": {
        "studies": {
          "@id": "mif:namespace/episodic/studies",
          "@type": "mif:Namespace",
          "name": "studies",
          "description": "Studies, investigations, cohorts",
          "type_hint": "episodic"
        },
        "provenance": {
          "@id": "mif:namespace/episodic/provenance",
          "@type": "mif:Namespace",
          "name": "provenance",
          "description": "Data provenance and derivation events",
          "type_hint": "episodic"
        }
      }
    },
    "procedural": {
      "@id": "mif:namespace/procedural",
      "@type": "mif:Namespace",
      "name": "procedural",
      "children": {
        "protocols": {
          "@id": "mif:namespace/procedural/protocols",
          "@type": "mif:Namespace",
          "name": "protocols",
          "description": "Methods and protocol applications",
          "type_hint": "procedural"
        }
      }
    }
  },
  "entity_types": [
    {
      "@id": "mif:entityType/study",
      "@type": "mif:EntityType",
      "name": "study",
      "base": "episodic",
      "description": "A scientific study with a defined design",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/stakeholders"
      ],
      "subtype_of": [
        "mif:entityType/inquiry"
      ],
      "schema": {
        "required": [
          "study_id",
          "title"
        ],
        "properties": {
          "study_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "study_type": {
            "type": "string",
            "enum": [
              "observational",
              "experimental",
              "randomized-controlled",
              "cohort",
              "case-control",
              "cross-sectional",
              "computational"
            ]
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "in-progress",
              "completed",
              "retracted"
            ]
          },
          "objective": {
            "type": "string"
          },
          "principal_investigator": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/research-investigation",
      "@type": "mif:EntityType",
      "name": "research-investigation",
      "base": "episodic",
      "description": "A research investigation spanning planning, execution and reporting",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated",
        "mif:trait/stakeholders"
      ],
      "subtype_of": [
        "mif:entityType/inquiry"
      ],
      "schema": {
        "required": [
          "investigation_id",
          "title"
        ],
        "properties": {
          "investigation_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "active",
              "completed",
              "published",
              "retracted"
            ]
          },
          "ethical_approval_id": {
            "type": "string"
          },
          "funding_ref": {
            "type": "string"
          },
          "publication_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/cohort",
      "@type": "mif:EntityType",
      "name": "cohort",
      "base": "episodic",
      "description": "A defined study population (subjects of an investigation)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "subtype_of": [
        "mif:entityType/inquiry"
      ],
      "schema": {
        "required": [
          "cohort_id"
        ],
        "properties": {
          "cohort_id": {
            "type": "string"
          },
          "cohort_size": {
            "type": "integer"
          },
          "inclusion_criteria": {
            "type": "string"
          },
          "exclusion_criteria": {
            "type": "string"
          },
          "study_ref": {
            "type": "string"
          },
          "follow_up_duration": {
            "type": "string"
          },
          "demographics_summary": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/method",
      "@type": "mif:EntityType",
      "name": "method",
      "base": "procedural",
      "description": "A scientific method or assay",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "subtype_of": [
        "mif:entityType/research-procedure"
      ],
      "schema": {
        "required": [
          "method_name",
          "method_type"
        ],
        "properties": {
          "method_name": {
            "type": "string"
          },
          "method_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "instrument_ref": {
            "type": "string"
          },
          "reagents": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "output_type": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/protocol-application",
      "@type": "mif:EntityType",
      "name": "protocol-application",
      "base": "procedural",
      "description": "The execution of a protocol (distinct from the method specification)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/dated"
      ],
      "subtype_of": [
        "mif:entityType/research-procedure"
      ],
      "schema": {
        "required": [
          "protocol_name"
        ],
        "properties": {
          "protocol_name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "procedure_steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "protocol_type": {
            "type": "string"
          },
          "ethics_approval_id": {
            "type": "string"
          },
          "doi": {
            "type": "string",
            "format": "uri"
          },
          "instrument_requirements": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/sample-organism",
      "@type": "mif:EntityType",
      "name": "sample-organism",
      "base": "semantic",
      "description": "A material sample (organism, tissue, or specimen)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "sample_id",
          "organism_name"
        ],
        "properties": {
          "sample_id": {
            "type": "string"
          },
          "taxon_id": {
            "type": "string"
          },
          "organism_name": {
            "type": "string"
          },
          "tissue_type": {
            "type": "string"
          },
          "collection_date": {
            "type": "string",
            "format": "date"
          },
          "preservation_method": {
            "type": "string"
          },
          "collection_site": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/measurement",
      "@type": "mif:EntityType",
      "name": "measurement",
      "base": "semantic",
      "description": "A measurement datum (a value specification)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "subtype_of": [
        "mif:entityType/observation"
      ],
      "schema": {
        "required": [
          "measurement_id",
          "value"
        ],
        "properties": {
          "measurement_id": {
            "type": "string"
          },
          "measured_property": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "measurement_method": {
            "type": "string"
          },
          "instrument_ref": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/hypothesis",
      "@type": "mif:EntityType",
      "name": "hypothesis",
      "base": "semantic",
      "description": "A falsifiable scientific hypothesis",
      "traits": [
        "mif:trait/cited"
      ],
      "subtype_of": [
        "mif:entityType/proposition"
      ],
      "schema": {
        "required": [
          "statement",
          "investigation_ref"
        ],
        "properties": {
          "statement": {
            "type": "string"
          },
          "investigation_ref": {
            "type": "string"
          },
          "hypothesis_type": {
            "type": "string",
            "enum": [
              "null",
              "directional",
              "mechanistic",
              "predictive",
              "exploratory"
            ]
          },
          "operationalization": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "untested",
              "supported",
              "refuted",
              "inconclusive"
            ]
          },
          "derived_from": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/research-instrument",
      "@type": "mif:EntityType",
      "name": "research-instrument",
      "base": "semantic",
      "description": "A research instrument or device",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned"
      ],
      "subtype_of": [
        "mif:entityType/apparatus"
      ],
      "schema": {
        "required": [
          "instrument_id",
          "instrument_type"
        ],
        "properties": {
          "instrument_id": {
            "type": "string"
          },
          "instrument_type": {
            "type": "string",
            "enum": [
              "sequencer",
              "mass-spectrometer",
              "microscope",
              "assay-platform",
              "imaging-device",
              "survey-platform",
              "flow-cytometer",
              "other"
            ]
          },
          "manufacturer": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "serial_number": {
            "type": "string"
          },
          "calibration_date": {
            "type": "string",
            "format": "date"
          },
          "location": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/research-publication",
      "@type": "mif:EntityType",
      "name": "research-publication",
      "base": "semantic",
      "description": "A research publication or scholarly output",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/documented"
      ],
      "subtype_of": [
        "mif:entityType/scholarly-output"
      ],
      "schema": {
        "required": [
          "title",
          "publication_type"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "publication_type": {
            "type": "string",
            "enum": [
              "journal-article",
              "preprint",
              "book-chapter",
              "conference-paper",
              "dataset-descriptor",
              "technical-report"
            ]
          },
          "doi": {
            "type": "string",
            "format": "uri"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "journal_or_venue": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          },
          "reports_investigation": {
            "type": "string"
          },
          "open_access": {
            "type": "boolean"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/research-funding",
      "@type": "mif:EntityType",
      "name": "research-funding",
      "base": "semantic",
      "description": "A grant providing monetary support for research",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "subtype_of": [
        "mif:entityType/funding-instrument"
      ],
      "schema": {
        "required": [
          "grant_id",
          "funder_name"
        ],
        "properties": {
          "grant_id": {
            "type": "string"
          },
          "funder_name": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "funding_scheme": {
            "type": "string"
          },
          "investigation_ref": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/dataset",
      "@type": "mif:EntityType",
      "name": "dataset",
      "base": "semantic",
      "description": "A published dataset",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/documented"
      ],
      "subtype_of": [
        "mif:entityType/research-artifact"
      ],
      "schema": {
        "required": [
          "title",
          "identifier"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "identifier": {
            "type": "string"
          },
          "theme": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "temporal_coverage": {
            "type": "string"
          },
          "spatial_coverage": {
            "type": "string"
          },
          "creator": {
            "type": "string"
          },
          "distribution_ref": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "mif:entityType/data-distribution",
      "@type": "mif:EntityType",
      "name": "data-distribution",
      "base": "semantic",
      "description": "A specific representation of a dataset (a downloadable/accessible form)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/documented"
      ],
      "subtype_of": [
        "mif:entityType/research-artifact"
      ],
      "schema": {
        "required": [
          "access_url",
          "dataset_ref"
        ],
        "properties": {
          "access_url": {
            "type": "string",
            "format": "uri"
          },
          "download_url": {
            "type": "string",
            "format": "uri"
          },
          "media_type": {
            "type": "string"
          },
          "byte_size": {
            "type": "integer"
          },
          "format": {
            "type": "string"
          },
          "checksum": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "dataset_ref": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/data-service",
      "@type": "mif:EntityType",
      "name": "data-service",
      "base": "semantic",
      "description": "A data access service (an endpoint serving datasets)",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/documented"
      ],
      "subtype_of": [
        "mif:entityType/research-artifact"
      ],
      "schema": {
        "required": [
          "endpoint_url"
        ],
        "properties": {
          "endpoint_url": {
            "type": "string",
            "format": "uri"
          },
          "endpoint_description": {
            "type": "string"
          },
          "serves_dataset": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "contact_point": {
            "type": "string"
          },
          "license": {
            "type": "string"
          },
          "access_rights": {
            "type": "string",
            "enum": [
              "open",
              "restricted",
              "embargoed"
            ]
          },
          "service_type": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/dataset-series",
      "@type": "mif:EntityType",
      "name": "dataset-series",
      "base": "semantic",
      "description": "A collection of datasets published as a series",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/documented"
      ],
      "subtype_of": [
        "mif:entityType/research-artifact"
      ],
      "schema": {
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "temporal_coverage": {
            "type": "string"
          },
          "frequency": {
            "type": "string"
          },
          "first_member_ref": {
            "type": "string"
          },
          "last_member_ref": {
            "type": "string"
          },
          "theme": {
            "type": "string"
          },
          "license": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/data-catalog",
      "@type": "mif:EntityType",
      "name": "data-catalog",
      "base": "semantic",
      "description": "A curated catalog of datasets and services",
      "traits": [
        "mif:trait/cited",
        "mif:trait/versioned",
        "mif:trait/documented"
      ],
      "subtype_of": [
        "mif:entityType/research-artifact"
      ],
      "schema": {
        "required": [
          "title",
          "catalog_url"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "catalog_url": {
            "type": "string",
            "format": "uri"
          },
          "publisher": {
            "type": "string"
          },
          "themes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dataset_count": {
            "type": "integer"
          },
          "license": {
            "type": "string"
          },
          "access_rights": {
            "type": "string",
            "enum": [
              "open",
              "restricted",
              "embargoed"
            ]
          }
        }
      }
    },
    {
      "@id": "mif:entityType/data-provenance",
      "@type": "mif:EntityType",
      "name": "data-provenance",
      "base": "episodic",
      "description": "A provenance record tracing how a data artifact was generated and derived",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "entity_ref",
          "generated_by"
        ],
        "properties": {
          "entity_ref": {
            "type": "string"
          },
          "generated_by": {
            "type": "string"
          },
          "derived_from": {
            "type": "string"
          },
          "attributed_to": {
            "type": "string"
          },
          "generation_time": {
            "type": "string",
            "format": "date-time"
          },
          "usage_ref": {
            "type": "string"
          },
          "revision_of": {
            "type": "string"
          }
        }
      }
    }
  ],
  "relationships": {
    "catalogs": {
      "@id": "mif:relationship/catalogs",
      "@type": "mif:Relationship",
      "name": "catalogs",
      "description": "A data-catalog catalogs a dataset (dcat:dataset)",
      "from": [
        "mif:entityType/data-catalog"
      ],
      "to": [
        "mif:entityType/dataset"
      ],
      "symmetric": false
    },
    "funded-by": {
      "@id": "mif:relationship/funded-by",
      "@type": "mif:Relationship",
      "name": "funded-by",
      "description": "A research-investigation is funded by a research-funding grant (schema:funding)",
      "from": [
        "mif:entityType/research-investigation"
      ],
      "to": [
        "mif:entityType/research-funding"
      ],
      "symmetric": false
    },
    "has-input": {
      "@id": "mif:relationship/has-input",
      "@type": "mif:Relationship",
      "name": "has-input",
      "description": "A protocol-application has a sample-organism as input (RO:0002233 has input)",
      "from": [
        "mif:entityType/protocol-application"
      ],
      "to": [
        "mif:entityType/sample-organism"
      ],
      "symmetric": false
    },
    "has-output": {
      "@id": "mif:relationship/has-output",
      "@type": "mif:Relationship",
      "name": "has-output",
      "description": "A protocol-application has a measurement as output (RO:0002234 has output)",
      "from": [
        "mif:entityType/protocol-application"
      ],
      "to": [
        "mif:entityType/measurement"
      ],
      "symmetric": false
    },
    "is-about": {
      "@id": "mif:relationship/is-about",
      "@type": "mif:Relationship",
      "name": "is-about",
      "description": "An information artifact is about another entity (IAO:0000136 is about) \u2014 a hypothesis about a measurement, a publication about an investigation",
      "from": [
        "mif:entityType/hypothesis",
        "mif:entityType/research-publication"
      ],
      "to": [
        "mif:entityType/measurement",
        "mif:entityType/research-investigation"
      ],
      "symmetric": false
    },
    "participates-in": {
      "@id": "mif:relationship/participates-in",
      "@type": "mif:Relationship",
      "name": "participates-in",
      "description": "A sample-organism participates in a research-investigation (RO:0000056 participates in)",
      "from": [
        "mif:entityType/sample-organism"
      ],
      "to": [
        "mif:entityType/research-investigation"
      ],
      "symmetric": false
    },
    "was-derived-from": {
      "@id": "mif:relationship/was-derived-from",
      "@type": "mif:Relationship",
      "name": "was-derived-from",
      "description": "A data-provenance record traces a dataset derived from another (prov:wasDerivedFrom)",
      "from": [
        "mif:entityType/data-provenance"
      ],
      "to": [
        "mif:entityType/dataset"
      ],
      "symmetric": false
    },
    "was-generated-by": {
      "@id": "mif:relationship/was-generated-by",
      "@type": "mif:Relationship",
      "name": "was-generated-by",
      "description": "A dataset was generated by a protocol-application (prov:wasGeneratedBy)",
      "from": [
        "mif:entityType/dataset"
      ],
      "to": [
        "mif:entityType/protocol-application"
      ],
      "symmetric": false
    },
    "uses_method": {
      "@id": "mif:relationship/uses_method",
      "@type": "mif:Relationship",
      "name": "uses_method",
      "description": "A study uses a method (RO:0000056 participates-in)",
      "from": [
        "mif:entityType/study"
      ],
      "to": [
        "mif:entityType/method"
      ],
      "symmetric": false
    },
    "has_sample": {
      "@id": "mif:relationship/has_sample",
      "@type": "mif:Relationship",
      "name": "has_sample",
      "description": "A study has a sample (RO:0002233 has-input)",
      "from": [
        "mif:entityType/study"
      ],
      "to": [
        "mif:entityType/sample-organism"
      ],
      "symmetric": false
    },
    "produces": {
      "@id": "mif:relationship/produces",
      "@type": "mif:Relationship",
      "name": "produces",
      "description": "A method produces a measurement (RO:0002234 has-output)",
      "from": [
        "mif:entityType/method"
      ],
      "to": [
        "mif:entityType/measurement"
      ],
      "symmetric": false
    },
    "measured_on": {
      "@id": "mif:relationship/measured_on",
      "@type": "mif:Relationship",
      "name": "measured_on",
      "description": "A measurement is taken on a sample",
      "from": [
        "mif:entityType/measurement"
      ],
      "to": [
        "mif:entityType/sample-organism"
      ],
      "symmetric": false
    },
    "tests": {
      "@id": "mif:relationship/tests",
      "@type": "mif:Relationship",
      "name": "tests",
      "description": "An investigation tests a hypothesis",
      "from": [
        "mif:entityType/research-investigation"
      ],
      "to": [
        "mif:entityType/hypothesis"
      ],
      "symmetric": false
    },
    "applies": {
      "@id": "mif:relationship/applies",
      "@type": "mif:Relationship",
      "name": "applies",
      "description": "An investigation applies a protocol-application",
      "from": [
        "mif:entityType/research-investigation"
      ],
      "to": [
        "mif:entityType/protocol-application"
      ],
      "symmetric": false
    },
    "uses_instrument": {
      "@id": "mif:relationship/uses_instrument",
      "@type": "mif:Relationship",
      "name": "uses_instrument",
      "description": "A protocol-application uses a research-instrument",
      "from": [
        "mif:entityType/protocol-application"
      ],
      "to": [
        "mif:entityType/research-instrument"
      ],
      "symmetric": false
    },
    "reports_in": {
      "@id": "mif:relationship/reports_in",
      "@type": "mif:Relationship",
      "name": "reports_in",
      "description": "An investigation is reported in a publication (IAO:0000136 is-about)",
      "from": [
        "mif:entityType/research-investigation"
      ],
      "to": [
        "mif:entityType/research-publication"
      ],
      "symmetric": false
    },
    "funded_by": {
      "@id": "mif:relationship/funded_by",
      "@type": "mif:Relationship",
      "name": "funded_by",
      "description": "An investigation is funded by a grant (schema:funder)",
      "from": [
        "mif:entityType/research-investigation"
      ],
      "to": [
        "mif:entityType/research-funding"
      ],
      "symmetric": false
    },
    "enrolls": {
      "@id": "mif:relationship/enrolls",
      "@type": "mif:Relationship",
      "name": "enrolls",
      "description": "An investigation enrolls a cohort",
      "from": [
        "mif:entityType/research-investigation"
      ],
      "to": [
        "mif:entityType/cohort"
      ],
      "symmetric": false
    }
  },
  "discovery": {
    "enabled": true,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(study|trial|investigation|cohort|randomi[sz]ed controlled)\\b",
        "suggest_entity": "mif:entityType/study",
        "suggest_namespace": "_episodic/studies"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(assay|protocol|method|procedure|RNA-seq|ChIP-seq)\\b",
        "suggest_entity": "mif:entityType/method",
        "suggest_namespace": "_semantic/science"
      },
      {
        "@id": "mif:pattern/2",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(specimen|material sample|organism|cell line|tissue|taxon)\\b",
        "suggest_entity": "mif:entityType/sample-organism",
        "suggest_namespace": "_semantic/science"
      },
      {
        "@id": "mif:pattern/3",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(measurement|measured value|reading|datum)\\b",
        "suggest_entity": "mif:entityType/measurement",
        "suggest_namespace": "_semantic/science"
      },
      {
        "@id": "mif:pattern/4",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(hypothesis|we hypothesi[sz]e|null hypothesis)\\b",
        "suggest_entity": "mif:entityType/hypothesis",
        "suggest_namespace": "_semantic/science"
      },
      {
        "@id": "mif:pattern/5",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(protocol application|batch|run performed|executed protocol)\\b",
        "suggest_entity": "mif:entityType/protocol-application",
        "suggest_namespace": "_procedural/protocols"
      },
      {
        "@id": "mif:pattern/6",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(ClinicalTrials\\.gov|OSF|PROSPERO|multi-omics)\\b",
        "suggest_entity": "mif:entityType/research-investigation",
        "suggest_namespace": "_episodic/studies"
      },
      {
        "@id": "mif:pattern/7",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(sequencer|mass spectrometer|microscope|flow cytometer|instrument)\\b",
        "suggest_entity": "mif:entityType/research-instrument",
        "suggest_namespace": "_semantic/instruments"
      },
      {
        "@id": "mif:pattern/8",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(DOI|preprint|journal article|ScholarlyArticle)\\b",
        "suggest_entity": "mif:entityType/research-publication",
        "suggest_namespace": "_semantic/publications"
      },
      {
        "@id": "mif:pattern/9",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(MonetaryGrant|grant number|funded by|award)\\b",
        "suggest_entity": "mif:entityType/research-funding",
        "suggest_namespace": "_semantic/funding"
      },
      {
        "@id": "mif:pattern/10",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(dataset|data catalog|DCAT|distribution|data download)\\b",
        "suggest_entity": "mif:entityType/dataset",
        "suggest_namespace": "_semantic/catalogs"
      },
      {
        "@id": "mif:pattern/11",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(prov:wasDerivedFrom|provenance|lineage|wasGeneratedBy)\\b",
        "suggest_entity": "mif:entityType/data-provenance",
        "suggest_namespace": "_episodic/provenance"
      }
    ]
  }
}