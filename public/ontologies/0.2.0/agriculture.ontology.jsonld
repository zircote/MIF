{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://mif-spec.dev/ns/ontology#",
    "mif": "https://mif-spec.dev/ns/",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ontology": {
      "@id": "mif:Ontology",
      "@type": "@id"
    },
    "id": {
      "@id": "@id"
    },
    "version": {
      "@id": "schema:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "schema_url": {
      "@id": "rdfs:isDefinedBy",
      "@type": "@id"
    },
    "namespaces": {
      "@id": "mif:hasNamespace",
      "@container": "@id"
    },
    "type_hint": {
      "@id": "mif:typeHint",
      "@type": "xsd:string"
    },
    "replaces": {
      "@id": "mif:replaces",
      "@type": "@id"
    },
    "children": {
      "@id": "mif:hasChildNamespace",
      "@container": "@id"
    },
    "entity_types": {
      "@id": "mif:definesEntityType",
      "@container": "@list"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "base": {
      "@id": "mif:baseType",
      "@type": "@vocab"
    },
    "semantic": "mif:SemanticMemory",
    "episodic": "mif:EpisodicMemory",
    "procedural": "mif:ProceduralMemory",
    "traits": {
      "@id": "mif:definesTrait",
      "@container": "@id"
    },
    "subtype_of": {
      "@id": "mif:subtypeOf",
      "@type": "@id",
      "@container": "@set"
    },
    "fields": {
      "@id": "mif:hasField",
      "@container": "@id"
    },
    "requires": {
      "@id": "mif:requiresField",
      "@container": "@list"
    },
    "relationships": {
      "@id": "mif:definesRelationship",
      "@container": "@id"
    },
    "from": {
      "@id": "rdfs:domain",
      "@container": "@set"
    },
    "to": {
      "@id": "rdfs:range",
      "@container": "@set"
    },
    "symmetric": {
      "@id": "owl:SymmetricProperty",
      "@type": "xsd:boolean"
    },
    "discovery": {
      "@id": "mif:discoveryConfig"
    },
    "enabled": {
      "@id": "mif:discoveryEnabled",
      "@type": "xsd:boolean"
    },
    "patterns": {
      "@id": "mif:hasDiscoveryPattern",
      "@container": "@list"
    },
    "confidence_threshold": {
      "@id": "mif:confidenceThreshold",
      "@type": "xsd:decimal"
    },
    "content_pattern": {
      "@id": "mif:contentPattern",
      "@type": "xsd:string"
    },
    "file_pattern": {
      "@id": "mif:filePattern",
      "@type": "xsd:string"
    },
    "suggest_entity": {
      "@id": "mif:suggestsEntityType",
      "@type": "@id"
    },
    "suggest_namespace": {
      "@id": "mif:suggestsNamespace",
      "@type": "xsd:string"
    }
  },
  "@id": "mif:ontology/agriculture",
  "@type": "mif:Ontology",
  "identifier": "agriculture",
  "version": "0.1.0",
  "description": "Shared farm supertypes \u2014 the MIF-compliant intermediate layer the agriculture domains extend",
  "namespaces": {
    "semantic": {
      "@id": "mif:namespace/semantic",
      "@type": "mif:Namespace",
      "name": "semantic",
      "children": {
        "farm": {
          "@id": "mif:namespace/semantic/farm",
          "@type": "mif:Namespace",
          "name": "farm",
          "description": "Farm operations, land, and resources",
          "type_hint": "semantic"
        }
      }
    },
    "episodic": {
      "@id": "mif:namespace/episodic",
      "@type": "mif:Namespace",
      "name": "episodic",
      "children": {
        "records": {
          "@id": "mif:namespace/episodic/records",
          "@type": "mif:Namespace",
          "name": "records",
          "description": "Farm episodic records \u2014 harvest and climate events",
          "type_hint": "episodic"
        }
      }
    }
  },
  "entity_types": [
    {
      "@id": "mif:entityType/agricultural-holding",
      "@type": "mif:EntityType",
      "name": "agricultural-holding",
      "base": "semantic",
      "description": "An agricultural operation or enterprise",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "operation_type": {
            "type": "string",
            "description": "crop / livestock / mixed"
          },
          "size": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/land-parcel",
      "@type": "mif:EntityType",
      "name": "land-parcel",
      "base": "semantic",
      "description": "A field, parcel, or paddock within a holding",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "area": {
            "type": "string"
          },
          "location": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/soil-unit",
      "@type": "mif:EntityType",
      "name": "soil-unit",
      "base": "semantic",
      "description": "A soil profile or soil mapping unit",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "soil_type": {
            "type": "string"
          },
          "organic_matter": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/cultivar",
      "@type": "mif:EntityType",
      "name": "cultivar",
      "base": "semantic",
      "description": "A crop, cultivar, or planting subject",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "species": {
            "type": "string"
          },
          "variety": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/managed-animal",
      "@type": "mif:EntityType",
      "name": "managed-animal",
      "base": "semantic",
      "description": "An animal or herd kept on the holding",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "species": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/agricultural-input",
      "@type": "mif:EntityType",
      "name": "agricultural-input",
      "base": "semantic",
      "description": "An input applied on the holding (seed, feed, fertilizer, amendment)",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "input_type": {
            "type": "string",
            "description": "seed / feed / fertilizer / amendment / pesticide"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/agricultural-equipment",
      "@type": "mif:EntityType",
      "name": "agricultural-equipment",
      "base": "semantic",
      "description": "A machine, implement, or piece of farm equipment",
      "traits": [
        "mif:trait/cited"
      ],
      "schema": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "equipment_type": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/harvest-event",
      "@type": "mif:EntityType",
      "name": "harvest-event",
      "base": "episodic",
      "description": "An episodic record of a harvest event and its yield",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "cultivar_ref"
        ],
        "properties": {
          "cultivar_ref": {
            "type": "string",
            "description": "The cultivar harvested"
          },
          "harvest_date": {
            "type": "string",
            "format": "date"
          },
          "yield": {
            "type": "string"
          }
        }
      }
    },
    {
      "@id": "mif:entityType/climate-event",
      "@type": "mif:EntityType",
      "name": "climate-event",
      "base": "episodic",
      "description": "An episodic climate/weather event affecting the operation",
      "traits": [
        "mif:trait/cited",
        "mif:trait/dated"
      ],
      "schema": {
        "required": [
          "event_type"
        ],
        "properties": {
          "event_type": {
            "type": "string",
            "description": "drought / frost / flood / storm / heatwave"
          },
          "event_date": {
            "type": "string",
            "format": "date"
          },
          "impact": {
            "type": "string"
          }
        }
      }
    }
  ],
  "traits": {
    "cited": {
      "@id": "mif:trait/cited",
      "@type": "mif:Trait",
      "name": "cited",
      "description": "Requires citations/sources",
      "requires": [
        "citations"
      ]
    },
    "dated": {
      "@id": "mif:trait/dated",
      "@type": "mif:Trait",
      "name": "dated",
      "description": "Adds an event/observation date",
      "fields": {
        "event_date": {
          "type": "string",
          "format": "date"
        }
      }
    }
  },
  "relationships": {
    "sited-in": {
      "@id": "mif:relationship/sited-in",
      "@type": "mif:Relationship",
      "name": "sited-in",
      "description": "A parcel is sited in a holding",
      "from": [
        "mif:entityType/land-parcel"
      ],
      "to": [
        "mif:entityType/agricultural-holding"
      ],
      "symmetric": false
    },
    "cultivates": {
      "@id": "mif:relationship/cultivates",
      "@type": "mif:Relationship",
      "name": "cultivates",
      "description": "A parcel cultivates a cultivar",
      "from": [
        "mif:entityType/land-parcel"
      ],
      "to": [
        "mif:entityType/cultivar"
      ],
      "symmetric": false
    },
    "amends": {
      "@id": "mif:relationship/amends",
      "@type": "mif:Relationship",
      "name": "amends",
      "description": "An input is applied to a parcel or cultivar",
      "from": [
        "mif:entityType/agricultural-input"
      ],
      "to": [
        "mif:entityType/land-parcel",
        "mif:entityType/cultivar"
      ],
      "symmetric": false
    }
  },
  "discovery": {
    "enabled": false,
    "confidence_threshold": 0.8,
    "patterns": [
      {
        "@id": "mif:pattern/0",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(farm|ranch|holding|operation)\\b",
        "suggest_entity": "mif:entityType/agricultural-holding",
        "suggest_namespace": "_semantic/farm"
      },
      {
        "@id": "mif:pattern/1",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(field|parcel|paddock|plot)\\b",
        "suggest_entity": "mif:entityType/land-parcel",
        "suggest_namespace": "_semantic/farm"
      },
      {
        "@id": "mif:pattern/2",
        "@type": "mif:DiscoveryPattern",
        "content_pattern": "\\b(crop|cultivar|planting)\\b",
        "suggest_entity": "mif:entityType/cultivar",
        "suggest_namespace": "_semantic/farm"
      }
    ]
  }
}